<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Market Dashboard</title>
    <link rel="stylesheet" href="/css/market-page.css">
</head>

<body>

    <h1>Welcome, <%= user.name %>!</h1>
    <a href="/logout">Logout</a>

    <hr>

    <div>
        <h2>Update Profile</h2>
        <form action="/market/update-profile" method="POST">
            <p>
                <label>Market Name:</label><br>
                <input type="text" name="name" value="<%= user.name %>" required>
            </p>
            <p>
                <label>City:</label><br>
                <input type="text" name="city" value="<%= user.city %>" required>
            </p>
            <p>
                <label>District:</label><br>
                <input type="text" name="district" value="<%= user.district %>" required>
            </p>
            <p>
                <label>New Password (Leave it blank to keep current):</label><br>
                <input type="password" name="password" placeholder="New Password">
            </p>
            <button type="submit" onclick="return confirm('Are you sure you want to update your information?')">Update
                Information</button>
        </form>
    </div>
    <hr>
    <div>
        <h2>Add New Product</h2>
        <form action="/market/add-product" method="POST" enctype="multipart/form-data" id="add-product-form">
            <p><input type="text" name="title" placeholder="Product Title" required></p>
            <p><input type="number" name="stock" placeholder="Stock Quantity" required></p>
            <p><input type="number" step="0.01" name="normal_price" placeholder="Normal Price (TL)" required></p>
            <p><input type="number" step="0.01" name="discounted_price" placeholder="Discounted Price (TL)" required>
            </p>
            <p><label>Expiration Date:</label><br><input type="date" name="expiration_date" required></p>

            <p><label>Product Image:</label><br>
                <input type="file" name="image" accept="image/*" required>
            </p>

            <button type="submit">Add Product to Inventory</button>
        </form>
    </div>

    <hr>

    <div>
        <h2>Your Inventory</h2>

        <% const today=new Date(); today.setHours(0,0,0,0); %>

            <% if(products.length===0) { %>
                <p>Your inventory is currently empty.</p>
                <% } %>

                    <% products.forEach(product=> {
                        const expDate = new Date(product.expiration_date);
                        const isExpired = expDate < today; %>
                            <div style="border: 1px solid black; margin-bottom: 20px; padding: 10px;">
                                <img src="/images/<%= product.image %>" alt="<%= product.title %>" width="150">

                                <% if(isExpired) { %>
                                    <p><strong>[EXPIRED ITEM]</strong></p>
                                    <% } %>

                                        <h3>
                                            <%= product.title %>
                                        </h3>
                                        <p>Stock: <%= product.stock %> units</p>
                                        <p>
                                            Price: <s>
                                                <%= product.normal_price %> TL
                                            </s>
                                            <strong>
                                                <%= product.discounted_price %> TL
                                            </strong>
                                        </p>
                                        <p>Expiration Date: <%= expDate.toISOString().split('T')[0] %>
                                        </p>

                                        <details>
                                            <summary>Edit Product Details</summary>
                                            <form action="/market/edit-product/<%= product.id %>" method="POST"
                                                enctype="multipart/form-data">
                                                <p>Title: <input type="text" name="title" value="<%= product.title %>"
                                                        required></p>
                                                <p>Stock: <input type="number" name="stock" value="<%= product.stock %>"
                                                        required></p>
                                                <p>Normal Price: <input type="number" step="0.01" name="normal_price"
                                                        value="<%= product.normal_price %>" required></p>
                                                <p>Discounted Price: <input type="number" step="0.01"
                                                        name="discounted_price" value="<%= product.discounted_price %>"
                                                        required></p>
                                                <p>Expiration: <input type="date" name="expiration_date"
                                                        value="<%= expDate.toISOString().split('T')[0] %>" required></p>

                                                <p>Update Image (Leave blank to keep current):<br>
                                                    <input type="file" name="image" accept="image/*">
                                                </p>
                                                <p style="font-size: 0.8rem; color: gray;">Current: <%= product.image %>
                                                </p>

                                                <button type="submit">Save Changes</button>
                                            </form>
                                        </details>

                                        <form action="/market/delete-product/<%= product.id %>" method="POST"
                                            style="margin-top: 10px;">
                                            <button type="submit"
                                                onclick="return confirm('Are you sure you want to delete this product?')">
                                                Delete This Product
                                            </button>
                                        </form>
                            </div>
                            <% }) %>
    </div>

    <script>
        document.getElementById('add-product-form').addEventListener('submit', function (event) {
            const fileInput = document.querySelector('input[name="image"]');
            const fileName = fileInput.value;
            const allowedExtensions = /(\.jpg|\.jpeg|\.png|\.gif)$/i;

            if (fileName && !allowedExtensions.exec(fileName)) {
                event.preventDefault()
                alert("Invalid file type. Only JPG, JPEG, PNG, and GIF are allowed.")
                return
            }
            const inputDate = document.querySelector('input[name="expiration_date"]').value
            const today = new Date().toISOString().split('T')[0]
            if (inputDate < today) {
                event.preventDefault()
                alert("Expiration date cannot be in the past!")
                return
            }
            const normalPrice = parseFloat(document.querySelector('#add-product-form input[name="normal_price"]').value);
            const discountedPrice = parseFloat(document.querySelector('#add-product-form input[name="discounted_price"]').value);

            if (discountedPrice > normalPrice) {
                event.preventDefault();
                alert("The discounted price cannot be higher than the regular price!");
            }
        })
    </script>
</body>

</html>