<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Market Dashboard</title>
    <style>
        body { font-family: Arial, sans-serif; padding: 20px; }
        .section { margin-bottom: 30px; padding: 20px; border: 1px solid #ccc; border-radius: 8px; }
        .product-card { border: 1px solid #ddd; padding: 15px; margin-bottom: 15px; border-radius: 5px; display: inline-block; width: 30%; vertical-align: top; }
        .expired { border: 2px solid red; background-color: #ffe6e6; }
        .expired-label { color: red; font-weight: bold; }
        img { max-width: 100%; height: auto; }
        input, button { margin-bottom: 10px; padding: 8px; width: 100%; box-sizing: border-box; }
        button { cursor: pointer; background-color: #28a745; color: white; border: none; }
        .btn-delete { background-color: #dc3545; }
        .btn-edit { background-color: #ffc107; color: black; }
        .grid { display: flex; gap: 15px; flex-wrap: wrap; }
    </style>
</head>
<body>

    <h1>Welcome, <%= user.name %>!</h1>
    <a href="/logout">Logout</a>

    <div class="section">
        <h2>Update Profile</h2>
        <form action="/market/update-profile" method="POST">
            <label>Market Name:</label>
            <input type="text" name="name" value="<%= user.name %>" required>
            <label>City:</label>
            <input type="text" name="city" value="<%= user.city %>" required>
            <label>District:</label>
            <input type="text" name="district" value="<%= user.district %>" required>
            <button type="submit">Update Information</button>
        </form>
    </div>

    <div class="section">
        <h2>Add New Product</h2>
        <form action="/market/add-product" method="POST">
            <input type="text" name="title" placeholder="Product Title (e.g. Toblerone 100gr)" required>
            <input type="number" name="stock" placeholder="Stock" required>
            <input type="number" step="0.01" name="normal_price" placeholder="Normal Price (TL)" required>
            <input type="number" step="0.01" name="discounted_price" placeholder="Discounted Price (TL)" required>
            <input type="date" name="expiration_date" required>
            <input type="text" name="image" placeholder="Image URL" required>
            <button type="submit">Add Product</button>
        </form>
    </div>

    <div class="section">
        <h2>Your Products</h2>
        <div class="grid">
            <% 
                const today = new Date();
                today.setHours(0,0,0,0);
            %>
            
            <% products.forEach(product => { 
                const expDate = new Date(product.expiration_date);
                const isExpired = expDate < today; 
            %> <!--for deadline-->
                <div class="product-card <%= isExpired ? 'expired' : '' %>"> 
                    <img src="<%= product.image %>" alt="<%= product.title %>">
                    <h3><%= product.title %></h3>
                    <p>Stock: <%= product.stock %></p>
                    <p>Price: <del><%= product.normal_price %> TL</del> <b><%= product.discounted_price %> TL</b></p>
                    <p>Expiration Date: <%= expDate.toISOString().split('T')[0] %></p>
                    
                    <% if(isExpired) { %>
                        <p class="expired-label">EXPIRED ITEM</p>
                    <% } %>

                    <form action="/market/edit-product/<%= product.id %>" method="POST" style="margin-top: 10px;">
                        <h4>Edit Product</h4>
                        <input type="text" name="title" value="<%= product.title %>" required>
                        <input type="number" name="stock" value="<%= product.stock %>" required>
                        <input type="number" step="0.01" name="normal_price" value="<%= product.normal_price %>" required>
                        <input type="number" step="0.01" name="discounted_price" value="<%= product.discounted_price %>" required>
                        <input type="date" name="expiration_date" value="<%= expDate.toISOString().split('T')[0] %>" required>
                        <input type="text" name="image" value="<%= product.image %>" required>
                        <button type="submit" class="btn-edit">Save Changes</button>
                    </form>

                    <form action="/market/delete-product/<%= product.id %>" method="POST">
                        <button type="submit" class="btn-delete" onclick="return confirm('Are you sure you want to delete this product?')">Delete Product</button>
                    </form>
                </div>
            <% }) %>
            
            <% if(products.length === 0) { %>
                <p>You have no products in your inventory.</p>
            <% } %>
        </div>
    </div>

</body>
</html>