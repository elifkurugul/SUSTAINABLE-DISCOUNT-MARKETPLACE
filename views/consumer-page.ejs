<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Consumer</title>
    <link rel="stylesheet" href="/css/consumer-page.css">
</head>
<body>
    <div>
        <p><b><%= user.name %></b>'s page!</p>
        <form action="/search" method="GET" class="search">
            <input type="text" name="keyword"
             value="<%= typeof (keyword) !== 'undefined' ? keyword : '' %>"
             placeholder="Type to search for products...">
            <button type="submit">Search</button>
        </form>

        <div class="cart-link">
            <a href="/api/cart">Cart</a>
        </div>

        <div class="consumer-profile-link">
            <a href="/profile">Profile</a>
        </div>

        <div class="logout">
            <a href="/logout">Logout</a>
        </div>
    </div>

    <% if (typeof (products) !== 'undefined') { %>
        <div class="search-banner">
            <% if (keyword.trim() === "") { %>
                 All products in your city (<b><%= user.city %></b>)
            <% } else { %>
                 Search results for "<b><%= keyword %></b>" in <b><%= user.city %></b>
            <% } %>
        </div>
        <% if (products.length > 0) { %>
            <div class="results">
                <% products.forEach( p => { %>
                    <div>
                        <img src="/images/<%= p.image %>">
                        <p>Title: <%= p.title %></p>
                        <p>Market Name: <%= p.name %></p>
                        <p>Discounted Price: <b><%= p.discounted_price %></b></p>
                        <p>Normal Price: <%= p.normal_price %></p>
                        <p>Stock: <%= p.stock %></p>
                        <p>City: <%= p.city %></p>
                        <p>District: <%= p.district %></p>
                        <p>Expiration Date: <b><%= new Date(p.expiration_date).toLocaleDateString() %></b></p>

                        <button class="add-to-cart-btn" data-id="<%= p.id %>">Add to Cart</button>
                    </div>
                <% }) %>
            </div>
            <div class="pagination">
                <% if (typeof (pageCount) !== 'undefined' && pageCount > 0) { %>
                    
                    <% if (page > 1) { %>
                        <a href="/search/?keyword=<%= keyword %>&page=<%= page - 1 %>" class="arrow">&lt;</a>
                    <% } else { %>
                        <span class="arrow inactive">&lt;</span>
                    <% } %>
                    <strong class="current-page"><%= page %></strong>
                    <% if (page < pageCount) { %>
                        <a href="/search/?keyword=<%= keyword %>&page=<%= page + 1 %>" class="arrow">&gt;</a>
                    <% } else { %>
                        <span class="arrow inactive">&gt;</span>
                    <% } %>
                <% } %>
            </div>
        <% } else { %>
            <p>No products found!</p>
        <% } %>
    <% } %>

    <!-- ADD TO CART AJAX -->
    <script>
        document.addEventListener('click', async (e) => {
            // Check if the clicked element is our add to cart button
            if (e.target.classList.contains('add-to-cart-btn')) {
                const button = e.target;
                const productId = button.getAttribute('data-id');
                
                // Optional: Change button text temporarily to show it's working
                const originalText = button.innerText;
                button.innerText = "Adding...";
                
                try {
                    // Send the AJAX POST request
                    const response = await fetch('/api/cart/add', {
                        method: 'POST',
                        headers: { 
                            'Content-Type': 'application/json' 
                        },
                        body: JSON.stringify({ productId: productId, quantity: 1 })
                    });
        
                    const data = await response.json();
        
                    if (response.ok && data.success) {
                        // Success UI update (using a simple alert as allowed by specs, or a toast if you have one)
                        button.innerText = "Added! 🎀";
                        button.style.backgroundColor = "var(--pink-deep)";
                        
                        // Reset button text after 2 seconds
                        setTimeout(() => {
                            button.innerText = originalText;
                            button.style.backgroundColor = "var(--pink-main)";
                        }, 2000);
                    } else {
                        alert(data.message || "Failed to add to cart.");
                        button.innerText = originalText;
                    }
                } catch (err) {
                    console.error('Fetch error:', err);
                    alert("Network error occurred.");
                    button.innerText = originalText;
                }
            }
        });
        </script>
</body>
</html>